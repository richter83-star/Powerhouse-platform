
[Unit]
Description=Powerhouse B2B Platform Backend API
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/powerhouse_b2b_platform/backend
Environment="PATH=/usr/local/bin:/usr/bin:/bin"
ExecStart=/usr/bin/python3 -m uvicorn api.main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=10
StandardOutput=append:/tmp/simple_backend.log
StandardError=append:/tmp/simple_backend.log

# Health check and auto-restart
HealthCheckInterval=30s

[Install]
WantedBy=multi-user.target
